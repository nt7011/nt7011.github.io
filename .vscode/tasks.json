{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run dev server",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "dev-server.py",
        "--bind",
        "127.0.0.1",
        "4173"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Serves http://127.0.0.1:4173/ with no-store cache headers"
    }
  ]
}
